# Optional API keys for routing a pipeline role to an external provider.
#
# Copy this file to `.env` and fill in only the keys you need. The pipeline is
# local-first: it reads a key ONLY when you name that provider in
# config/pipeline.yaml (e.g. `reviewer: openai:gpt-4o`). Leave everything blank
# to stay fully local on Ollama. `.env` is gitignored — never commit real keys.
#
# `agent-pipeline run` loads this file automatically; setup.sh scaffolds it.
# Either the standard name or the short alias is accepted.

# OpenAI — used by `openai:<model>` (e.g. openai:gpt-4o)
OPENAI_API_KEY=

# Google Gemini — used by `gemini:<model>` (e.g. gemini:gemini-1.5-pro)
GEMINI_API_KEY=

# Anthropic Claude — used by `claude:<model>` (e.g. claude:claude-sonnet-4-5)
ANTHROPIC_API_KEY=
